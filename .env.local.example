#OBRIGATORIO

## Supabase (obrigatório)
# URL do seu projeto Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Chave publishable/anon (Settings → API)
# Use a chave publishable `sb_publishable_...` se estiver disponível no seu projeto.
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY


##OPCIONAL


## Auth redirect (opcional)
# URL base do seu site (produção)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# URL de redirect para DEV (se quiser sobrescrever)
# Ex.: http://localhost:3000/auth/callback
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback
